# Production environment — copy to .env.prod and fill in values
DATABASE_URL=postgresql+asyncpg://nexus:STRONG_PASSWORD@postgres:5432/nexuscrm
POSTGRES_PASSWORD=STRONG_PASSWORD
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=REDIS_PASSWORD
SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=https://crm.yourdomain.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_API_URL=https://crm.yourdomain.com
